# Copy to .env and fill. Used by docker-compose (local Lambda test) and deploy-lambda.sh (env vars).
PORT=3456
APP_URL=https://springsummer2026margiela.com
PUBLIC_URL=https://v42svjp2rnfuvkhuaatp2z4oxm0ouluo.lambda-url.ap-southeast-1.on.aws

# Optional: when set, PDF generation failures are sent to this Slack webhook
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# S3 (recommended on Lambda): upload PDF to bucket → FE updates pdfUrl in DB when it receives response
# S3_BUCKET=margiela-pdfs
# S3_PREFIX=pdfs/
# S3_PRESIGNED_EXPIRY_SECONDS=604800
# Optional: use short public URL (no expiry). Set bucket policy to allow public read on pdfs/*, then:
# S3_PUBLIC_BASE_URL=https://margiela-pdfs.s3.ap-southeast-1.amazonaws.com
# Optional: if presigned URL gives AuthorizationQueryParametersError when opening in browser, try:
# S3_DISABLE_CHECKSUM=1
