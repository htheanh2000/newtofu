# Neon Data API + Neon Auth (admin gọi thẳng Neon, không qua margiela-fe)
# Lấy từ Neon Console: project → Data API page (API URL) và Auth page (Auth URL)
# Data API URL phải có /rest/v1 (SDK gọi .../User, .../Composition)
NEXT_PUBLIC_NEON_DATA_API_URL=https://your-project.apirest.region.aws.neon.tech/neondb/rest/v1
NEXT_PUBLIC_NEON_AUTH_URL=https://your-project.neonauth.region.aws.neon.tech/neondb/auth

# Link PDF (trang view) trong cột Composition ID: base URL của margiela-fe (vd. https://springsummer2026margiela.com)
# NEXT_PUBLIC_VIEW_BASE_URL=https://your-fe-domain.com

# Deploy to S3: npm run deploy:s3 (cần AWS CLI đã cấu hình)
# S3_BUCKET=bucket-name
# AWS_REGION=us-east-1
# CLOUDFRONT_DISTRIBUTION_ID=optional-for-cache-invalidation
