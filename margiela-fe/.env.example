# Neon PostgreSQL – compositions/users + device whitelist (required for ECS when whitelist is on)
# Lấy URL bằng Neon CLI (cài: npm i -g neonctl): neon connection-string --pooled --prisma
# Hoặc Neon Console → Connection string → pooled
DATABASE_URL=

# App URL (for QR code generation)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# PDF Generation Service (Lambda). Server-side: PDF_SERVICE_URL (recommended). See margiela-pdf/docs/aws-lambda-margiela-setup.md
PDF_SERVICE_URL=https://v42svjp2rnfuvkhuaatp2z4oxm0ouluo.lambda-url.ap-southeast-1.on.aws
NEXT_PUBLIC_PDF_SERVICE_URL=https://v42svjp2rnfuvkhuaatp2z4oxm0ouluo.lambda-url.ap-southeast-1.on.aws

# Device whitelist: only registered devices can load composition / generate PDF.
# Set to "1" or "true" to enable. Requires DATABASE_URL (Neon) so devices are stored in DB.
MARGIELA_DEVICE_WHITELIST_ENABLED=1

# Admin (margiela-admin): login account + secret for /api/admin/*
ADMIN_USERNAME=margiela
ADMIN_PASSWORD=springsummer2026margiela@
ADMIN_SECRET=springsummer2026margiela
# Restrict CORS to admin subdomain (recommended in prod). If unset, allows *.
ADMIN_CORS_ORIGIN=https://admin.springsummer2026margiela.com

# Slack: API error notifications (fire-and-forget; if webhook fails, API still responds normally)
SLACK_WEBHOOK_URL_API_ERROR=
